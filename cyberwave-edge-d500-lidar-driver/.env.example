# Copy to .env and fill in your values for local development.
# In production, Edge Core injects these automatically — no changes needed there.

CYBERWAVE_TWIN_UUID=your-twin-uuid-here
CYBERWAVE_API_KEY=your-api-key-here
CYBERWAVE_TWIN_JSON_FILE=/tmp/cyberwave-twin.json

# Optional: uncomment to tune Edge Core restart behaviour
# CYBERWAVE_DRIVER_RESTART_LOOP_THRESHOLD=4
# CYBERWAVE_DRIVER_RESTART_LOOP_WINDOW_SECONDS=60
# CYBERWAVE_DRIVER_TROUBLESHOOTING_URL=https://docs.cyberwave.com
